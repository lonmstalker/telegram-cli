# Контракт имён без значений. Реальные значения хранятся только в .env.local.
TELEGRAM_PROFILE=default
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TDLIB_DATABASE_DIR=
TDLIB_FILES_DIR=
# Base64-encoded raw TDLib database key, file mode 0600.
TDLIB_DATABASE_KEY_FILE=
TDLIB_USE_TEST_DC=false
TDJSON_LIBRARY_PATH=
# Optional stable account binding. On first successful getMe telegramd creates
# an owner-only marker beside the database when this is empty.
TELEGRAM_EXPECTED_USER_ID=
# Deployment setting for lazy local mode.
TELEGRAM_IDLE_TIMEOUT_MS=30000
# Comma-separated closed policy scopes; missing/empty means read-only.
TELEGRAM_RISK_SCOPES=read
# Optional Ed25519 public key (64 hex chars). Missing means dangerous plans can't be approved.
TELEGRAM_APPROVAL_PUBLIC_KEY_HEX=

# Phone, OTP и 2FA вводятся через защищённый auth flow и сюда не добавляются.
